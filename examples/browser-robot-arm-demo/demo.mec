+> @ui := ui/dom
+> @arm := arm/commands
+> @state := arm/state
x := @ui/x-slider/_value
y := @ui/y-slider/_value
z := @ui/z-slider/_value
closed := @ui/grip-toggle/_checked
@arm/move <- { x: x y: y z: z }
@arm/grip <- { closed: closed }
position := @state/position
gripper := @state/gripper
@ui/robot-state/_text = position
@ui/gripper-state/_text = gripper
