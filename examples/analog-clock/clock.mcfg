config := {
  hosts: [
    {
      name: "clock"
      provider: "time"
      settings: {
        interval-ms: 100
      }
    }
  ]
  run: {
    grants: [
      {
        target: "clock/clock"
        operations: ["read"]
        paths: ["unix-ms", "hour", "minute", "second", "millisecond"]
      }
    ]
  }
}
