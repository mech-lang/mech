config := {
  hosts: [
    {
      name: "clock"
      provider: "time"
      settings: {
        interval-ms: 1000
      }
    }
  ]
  run: {
    paths: [
      "clock.mec"
      "main.mec"
    ]
    grants: [
      {
        target: "clock/clock"
        operations: ["read"]
        paths: ["unix-ms", "hour", "minute", "second", "millisecond"]
      }
      {
        target: "cli/stdout"
        operations: ["write"]
        paths: ["line"]
      }
    ]
  }
}
