@sample := timer://sample/tick{:read(tick), :read(delta-seconds)}
@frame := scene://view/frame{:write(replace)}

sample-tick := @sample/tick
sampled-state := state

lines := |id<string> x1<f64> y1<f64> x2<f64> y2<f64> stroke<string> stroke-width<f64> line-cap<string> opacity<f64> rotation<f64> origin-x<f64> origin-y<f64>|
  | "reference" 0 90 120 90 "#555555" 1 "round" 1 0 0 0 |

scene := {
  width: 120
  height: 96
  background: "#000000"
  circles: sampled-state
  lines: lines
}

@frame/replace <- scene
