@tick := timer://tick/tick{:read(tick), :read(delta-seconds)}
@view := scene://view/frame{:write(replace)}

generic-tick := @tick/tick
generic-delta := @tick/delta-seconds

rows := |id<string> x<f64> y<f64> radius<f64> fill<string>|
  | "row-a" 20 + generic-delta 30 4 "#ffffff" |
  | "row-b" 40 + generic-delta 50 5 "#cccccc" |

lines := |id<string> x1<f64> y1<f64> x2<f64> y2<f64> stroke<string> stroke-width<f64> line-cap<string> opacity<f64> rotation<f64> origin-x<f64> origin-y<f64>|

scene := {
  width: 100
  height: 80
  background: "#000000"
  circles: rows
  lines: lines
}

@view/replace <- scene
