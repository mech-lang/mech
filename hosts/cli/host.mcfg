config := {
  host: {
    provider: "cli"
    contexts: [
      { name: "env" base-uri: "cli://{instance}/env" operations: ["read"] }
      { name: "stdout" base-uri: "cli://{instance}/stdout" operations: ["write"] }
      { name: "stderr" base-uri: "cli://{instance}/stderr" operations: ["write"] }
    ]
  }
}
